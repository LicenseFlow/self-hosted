{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"licenseflow\"}[5m])",
          "legendFormat": "{{method}} {{handler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15 } }
      }
    },
    {
      "title": "API Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"licenseflow\"}[5m]))",
          "legendFormat": "p95 {{handler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      }
    },
    {
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"licenseflow\", status=~\"5..\"}[5m])",
          "legendFormat": "{{handler}} ({{status}})",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "title": "Active Licenses",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "licenseflow_licenses_active_total",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "title": "Total Activations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "licenseflow_activations_total",
          "legendFormat": "Activations",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } }
      }
    },
    {
      "title": "License Activations Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(licenseflow_activations_total[1h])",
          "legendFormat": "Activations/hr",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }
      }
    },
    {
      "title": "Database Connection Pool",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"licenseflow\"}",
          "legendFormat": "Active",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 85 }
          ] }
        }
      }
    },
    {
      "title": "DB Query Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "rate(pg_stat_statements_mean_exec_time_ms{datname=\"licenseflow\"}[5m])",
          "legendFormat": "Avg query time",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"licenseflow\"}[5m]) * 100",
          "legendFormat": "CPU %",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"licenseflow\"}",
          "legendFormat": "RSS Memory",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20 } }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["licenseflow", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "LicenseFlow — Operations Dashboard",
  "uid": "licenseflow-ops",
  "version": 1
}
