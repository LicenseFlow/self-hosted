# LicenseFlow Self-Hosted Configuration
# Copy this file to .env and update the values

# ═══════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# PostgreSQL credentials
POSTGRES_USER=licenseflow
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=licenseflow

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════

# JWT secret for token signing (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# ═══════════════════════════════════════════════════════════════
# SUPABASE (Optional - for full feature compatibility)
# ═══════════════════════════════════════════════════════════════

# Leave blank for standalone mode, or configure for hybrid mode
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ═══════════════════════════════════════════════════════════════
# STRIPE INTEGRATION (Optional)
# ═══════════════════════════════════════════════════════════════

# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret for Stripe events
STRIPE_WEBHOOK_SECRET=whsec_...

# ═══════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════

# SMTP settings for sending emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════

# Public URL where the application is accessible
APP_URL=http://localhost:3000

# Version tag (optional)
VERSION=1.0.0

# ═══════════════════════════════════════════════════════════════
# STORAGE (MinIO / S3) - For Release Management
# ═══════════════════════════════════════════════════════════════

# MinIO root credentials (used by both MinIO and the app)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=strongpassword-change-me

# Storage settings
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=artifacts
# Public URL for downloading artifacts (usually your domain or CDN)
STORAGE_PUBLIC_URL=http://localhost:9000/artifacts

# ═══════════════════════════════════════════════════════════════
# ENVIRONMENT SCOPING
# ═══════════════════════════════════════════════════════════════

# Default environment for new organizations
DEFAULT_ENVIRONMENT=production
